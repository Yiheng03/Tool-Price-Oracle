{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cutting Tool Price Oracle Typed Report",
  "type": "object",
  "required": ["report_id", "report_type", "date", "title", "summary", "metals"],
  "properties": {
    "report_id": {
      "type": "string",
      "description": "Stable report id. File storage uses report_type plus metal topic and forecast/backtest date."
    },
    "report_type": {
      "type": "string",
      "enum": ["tool_price", "single_metal", "daily_briefing", "weekly_briefing", "backtest"],
      "description": "Controls validation, storage topic, HTML layout, and chat link label."
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Primary report date, usually the forecast/prediction date."
    },
    "prediction_date": {
      "type": "string",
      "format": "date"
    },
    "target_date": {
      "type": "string",
      "format": "date"
    },
    "actual_date": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO timestamp for the latest report update."
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "metals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "name", "spot_price", "unit", "direction", "range_pct", "confidence", "rationale"],
        "properties": {
          "code": { "type": "string" },
          "name": { "type": "string" },
          "spot_price": { "type": "number" },
          "unit": { "type": "string" },
          "source": { "type": "string" },
          "direction": { "type": "string", "enum": ["up", "down", "flat", "volatile"] },
          "range_pct": {
            "type": "array",
            "prefixItems": [{ "type": "number" }, { "type": "number" }],
            "minItems": 2,
            "maxItems": 2
          },
          "confidence": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "tool_cost_impact": {
      "type": "object",
      "description": "Required for tool_price reports.",
      "required": ["tool_spec", "base_cost", "next_day_low", "next_day_high", "main_driver"],
      "properties": {
        "tool_spec": { "type": "string" },
        "base_cost": { "type": "number" },
        "currency": { "type": "string" },
        "next_day_low": { "type": "number" },
        "next_day_high": { "type": "number" },
        "main_driver": { "type": "string" }
      }
    },
    "recommendation": {
      "type": "object",
      "description": "Purchasing or risk action. Required for tool_price reports and recommended for briefing reports.",
      "required": ["action", "reason", "risk_level"],
      "properties": {
        "action": { "type": "string" },
        "reason": { "type": "string" },
        "risk_level": { "type": "string" }
      }
    },
    "backtests": {
      "type": "array",
      "description": "Required for backtest reports unless json_payload.yesterday_backtest is verified.",
      "items": {
        "type": "object",
        "properties": {
          "metal": { "type": "string" },
          "prediction_date": { "type": "string" },
          "actual_date": { "type": "string" },
          "predicted_direction": { "type": "string" },
          "actual_direction": { "type": "string" },
          "hit_direction": { "type": "boolean" },
          "hit_range": { "type": "boolean" },
          "bias_reason": { "type": "string" },
          "next_adjustment": { "type": "string", "description": "Concrete adjustment rule for future predictions, generated by bias_review." }
        }
      }
    },
    "sections": {
      "type": "array",
      "description": "Typed free-form report sections for news, supply chain, demand, weekly learnings, or other type-specific content.",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "type": "string" }
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["key"],
              "properties": {
                "key": { "type": "string" },
                "label": { "type": "string" }
              }
            }
          },
          "rows": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    },
    "yesterday_review": {
      "type": "object",
      "description": "Yesterday prediction review. Required for tool_price and daily_briefing reports when prediction files exist for the prior trading day.",
      "required": ["headline", "summary", "backtests", "learnings_written"],
      "properties": {
        "headline": {
          "type": "string",
          "description": "One-line summary of yesterday's prediction accuracy, e.g. '2026-06-23 Review: 3/5 verified — 2 direction hits, 1 range hit. Misses: [NI-range, CO-direction].'"
        },
        "summary": {
          "type": "string",
          "description": "Detailed paragraph explaining hit rates, main bias reasons, and key takeaways."
        },
        "backtests": {
          "type": "array",
          "description": "One entry per verified metal with direction/range hit status and bias reasons. Empty on the first day when no one-day predictions were registered yesterday.",
          "items": {
            "type": "object",
            "properties": {
              "metal": { "type": "string" },
              "prediction_date": { "type": "string" },
              "actual_date": { "type": "string" },
              "predicted_direction": { "type": "string" },
              "actual_direction": { "type": "string" },
              "hit_direction": { "type": "boolean" },
              "hit_range": { "type": "boolean" },
              "bias_reason": { "type": "string" },
          "next_adjustment": { "type": "string", "description": "Concrete adjustment rule for future predictions, generated by bias_review." }
            }
          }
        },
        "learnings_written": {
          "type": "array",
          "description": "List of learnings files updated as a result of bias review.",
          "items": { "type": "string" }
        }
      }
    },
    "json_payload": {
      "type": "object",
      "description": "Optional raw agent output or extra structured fields."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "report_type": { "const": "tool_price" } }
      },
      "then": {
        "required": ["tool_cost_impact", "recommendation"]
      }
    },
    {
      "if": {
        "properties": { "report_type": { "enum": ["tool_price", "daily_briefing"] } }
      },
      "then": {
        "required": ["yesterday_review"]
      }
    }
  ]
}
